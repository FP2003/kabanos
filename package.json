{
  "name": "kabanos",
  "version": "1.0.0",
  "description": "A read-only code-comment kanban board for Node.js applications",
  "keywords": ["kanban", "todo", "fixme", "code-comments", "board", "express", "fastify", "nextjs", "technical-debt"],
  "homepage": "https://github.com/FP2003/kabanos#readme",
  "repository": { "type": "git", "url": "https://github.com/FP2003/kabanos.git" },
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": { "node": ">=22.13" },
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "bin": { "kabanos": "./dist/cli.js" },
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./express": { "types": "./dist/adapters/express.d.ts", "import": "./dist/adapters/express.js" },
    "./fastify": { "types": "./dist/adapters/fastify.d.ts", "import": "./dist/adapters/fastify.js" },
    "./next": { "types": "./dist/adapters/next.d.ts", "import": "./dist/adapters/next.js" },
    "./node": { "types": "./dist/adapters/node.d.ts", "import": "./dist/adapters/node.js" }
  },
  "scripts": {
    "build": "node scripts/clean.mjs && vite build && tsup",
    "demo": "npm run build && node demo/server.mjs",
    "demo:reset": "node demo/reset.mjs",
    "dev:ui": "vite",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:databases": "KABANOS_TEST_POSTGRES=postgres://kabanos:kabanos@127.0.0.1:55432/kabanos KABANOS_TEST_MYSQL=mysql://kabanos:kabanos@127.0.0.1:53306/kabanos vitest run test/storage-conformance.test.ts",
    "test:benchmark": "KABANOS_BENCHMARK=1 vitest run test/performance.test.ts",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "prepack": "npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "chokidar": "^4.0.3",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "kysely": "^0.28.5",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "zod": "^4.1.5"
  },
  "optionalDependencies": {
    "mysql2": "^3.14.4",
    "pg": "^8.16.3"
  },
  "peerDependencies": {
    "express": ">=4 <6",
    "fastify": ">=4 <6"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true },
    "fastify": { "optional": true }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@dnd-kit/accessibility": "^3.1.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@playwright/test": "^1.55.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.5",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "express": "^5.1.0",
    "fastify": "^5.6.0",
    "jsdom": "^26.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
